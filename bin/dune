(executable
 (name main)
 ; temporal_shim carries no modules; linking it embeds the vendored Temporal polyfill
 ; that core's timezone loader needs on browsers without native Temporal (Safari).
 (libraries
  core
  bonsai
  bonsai_web
  virtual_dom
  js_of_ocaml
  avalon_components
  temporal_shim)
 (flags
  (:standard -w +70 -warn-error +70))
 (preprocess
  (pps ppx_jane js_of_ocaml-ppx bonsai.ppx_bonsai))
 (js_of_ocaml
  (flags
   (--effects cps))
  (javascript_files runtime_avalon.js))
 (modes js))

(rule
 (target index.html)
 (deps ../web/index.html)
 (action
  (copy %{deps} %{target})))
